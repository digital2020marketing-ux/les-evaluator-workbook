rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProgress(data, userId) {
      return data.userId == userId &&
             data.userId == request.auth.uid &&
             (!data.keys().contains('childName') || (data.childName is string && data.childName.size() <= 128));
    }

    // 2. Users Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUserProgress(request.resource.data, userId);
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
